# Copy to .env and fill in (never commit .env)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional dev: leave unset so redirect_uri follows your browser via Vite
# GOOGLE_REDIRECT_URI=http://localhost:5173/api/google/oauth-callback
# FRONTEND_URL=http://localhost:5173
GOOGLE_TIMEZONE=Asia/Kolkata
# Optional
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# MEETING_WORK_START_HOUR=9
# MEETING_WORK_END_HOUR=18
